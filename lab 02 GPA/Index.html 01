<!DOCTYPEhtml >
<html lang="en">
<head >
<metacharset="UTF -8">
<title >GPACalculator </title >
<link rel="stylesheet" href="style.css">
<script src="script.js"></script >
</head >
<body >
<h1>GPACalculator </h1>
<formaction="calculate.php" method="post"
onsubmit="returnvalidateForm ();">
<div id="courses">
<div class="course -row">
<label >Course:</label >
<inputtype="text" name="course []"
placeholder="e.g. Mathematics" required >
<label >Credits:</label >
<inputtype="number" name="credits []"
placeholder="e.g. 3" min="1" required >
<label >Grade:</label >
<selectname="grade []">
<optionvalue="4.0">A</option >
<optionvalue="3.0">B</option >
<optionvalue="2.0">C</option >
<optionvalue="1.0">D</option >
<optionvalue="0.0">F</option >
</select >
</div>
</div>
<buttontype="button" onclick="addCourse ()">
+ Add Course
</button ><br><br>
<inputtype="submit" value="CalculateGPA">
</form >
</body >
</html >
